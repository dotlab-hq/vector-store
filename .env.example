# ──────────────────────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────────────────────
APP_NAME=vector-store
DEBUG=false

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI / LLM
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# ──────────────────────────────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@host:port

# ──────────────────────────────────────────────────────────────────────────────
# LangSmith (observability & tracing)
# ──────────────────────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=vector-store
LANGSMITH_TRACING=false

# ──────────────────────────────────────────────────────────────────────────────
# Embedding
# ──────────────────────────────────────────────────────────────────────────────
EMBEDDING_DIMENSION=1536

# ──────────────────────────────────────────────────────────────────────────────
# Chunking
# ──────────────────────────────────────────────────────────────────────────────
PARENT_CHUNK_MAX_TOKENS=1024
CHILD_CHUNK_MAX_TOKENS=256

# ──────────────────────────────────────────────────────────────────────────────
# Retrieval
# ──────────────────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=10
FUSION_K=60

# ──────────────────────────────────────────────────────────────────────────────
# Generation
# ──────────────────────────────────────────────────────────────────────────────
GENERATION_TEMPERATURE=0.3
MAX_CONTEXT_TOKENS=8000

# ──────────────────────────────────────────────────────────────────────────────
# S3 / MinIO Storage
# ──────────────────────────────────────────────────────────────────────────────
S3_BUCKET=vector-store
S3_REGION=us-east-1
S3_ENDPOINT=                                     # MinIO endpoint (leave empty for AWS S3)
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_PRESIGN_EXPIRY=900                            # Presigned URL lifetime in seconds (15 min)

# ──────────────────────────────────────────────────────────────────────────────
# Qdrant Vector Store
# ──────────────────────────────────────────────────────────────────────────────
# Precedence: qdrant_url (server) > qdrant_path (local on-disk) > in-memory (dev)
QDRANT_URL=                                       # e.g. http://localhost:6333 — leave empty for in-memory
QDRANT_API_KEY=                                   # Required for Qdrant Cloud
QDRANT_PREFER_GRPC=false
QDRANT_PATH=                                      # Local on-disk path — leave empty for in-memory
QDRANT_COLLECTION=rag_chunks

# ──────────────────────────────────────────────────────────────────────────────
# Neo4j Knowledge Graph
# ──────────────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j
NEO4J_ENABLED=false                               # Disabled by default until configured

# ──────────────────────────────────────────────────────────────────────────────
# Vector Store Worker / Cron
# ──────────────────────────────────────────────────────────────────────────────
VECTOR_STORE_WORKER_CONCURRENCY=2
VECTOR_STORE_WORKER_POLL_INTERVAL_S=1.0
VECTOR_STORE_WORKER_LEASE_MINUTES=10
VECTOR_STORE_RETRY_BASE_S=30
VECTOR_STORE_RETRY_CAP_S=3600
VECTOR_STORE_RETRY_MAX=5
VECTOR_STORE_CRON_INTERVAL_S=60.0
VECTOR_STORE_SEARCH_FANOUT=4
VECTOR_STORE_WORKER_ENABLED=true
